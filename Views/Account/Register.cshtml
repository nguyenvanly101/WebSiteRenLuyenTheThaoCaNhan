@model RegisterViewModel
@{
    ViewData["Title"] = "Đăng ký";
}

<section class="auth-shell">
    <div class="auth-copy js-reveal">
        <p class="eyebrow">Tạo tài khoản</p>
        <h1>Tạo tài khoản để bắt đầu sử dụng hệ thống.</h1>
        <p class="lead">Sau khi đăng ký, bạn có thể lập kế hoạch tập, đặt mục tiêu và ghi lại từng buổi tập trong cùng một nơi.</p>
        
    </div>

    <div class="auth-card js-reveal">
        <div class="auth-card__header">
            <p class="eyebrow">Biểu mẫu</p>
            <h2>Tạo tài khoản mới</h2>
            <p class="form-footnote">Điền thông tin cơ bản để bắt đầu sử dụng hệ thống.</p>
        </div>

        <form asp-action="Register" method="post" class="form-stack">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

            <div class="field">
                <label asp-for="FullName"></label>
                <input asp-for="FullName" class="form-control" />
                <span asp-validation-for="FullName" class="text-danger"></span>
            </div>

            <div class="field-grid">
                <div class="field">
                    <label asp-for="Username"></label>
                    <input asp-for="Username" class="form-control" />
                    <span asp-validation-for="Username" class="text-danger"></span>
                </div>
                <div class="field">
                    <label asp-for="Email"></label>
                    <input asp-for="Email" class="form-control" />
                    <span asp-validation-for="Email" class="text-danger"></span>
                </div>
            </div>

            <div class="field-grid">
                <div class="field">
                    <label asp-for="Password"></label>
                    <input asp-for="Password" class="form-control" />
                    <span asp-validation-for="Password" class="text-danger"></span>
                </div>
                <div class="field">
                    <label asp-for="ConfirmPassword"></label>
                    <input asp-for="ConfirmPassword" class="form-control" />
                    <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                </div>
            </div>

            <button type="submit" class="button button--block">Tạo tài khoản</button>
            <p class="form-footnote">Đã có tài khoản? <a asp-action="Login">Đăng nhập</a></p>
        </form>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
