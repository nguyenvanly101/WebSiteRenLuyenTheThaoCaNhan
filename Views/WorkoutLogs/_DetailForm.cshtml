@model WorkoutLogDetailFormViewModel

<div class="field">
    <label asp-for="ExerciseID"></label>
    <select asp-for="ExerciseID" asp-items="ViewBag.Exercises" class="form-select"></select>
    <span asp-validation-for="ExerciseID" class="text-danger"></span>
</div>

<div class="field-grid">
    <div class="field">
        <label asp-for="SetNumber"></label>
        <input asp-for="SetNumber" class="form-control" />
        <span asp-validation-for="SetNumber" class="text-danger"></span>
    </div>
    <div class="field">
        <label asp-for="Reps"></label>
        <input asp-for="Reps" class="form-control" />
        <span asp-validation-for="Reps" class="text-danger"></span>
    </div>
</div>

<div class="field">
    <label asp-for="Weight"></label>
    <input asp-for="Weight" class="form-control" />
    <span asp-validation-for="Weight" class="text-danger"></span>
</div>
