@model AdminDashboardViewModel
@{
    ViewData["Title"] = "Quản trị";
}

<section class="page-hero">
    <div>
        <p class="eyebrow">Tổng quan quản trị</p>
        <h1>Bảng điều khiển quản trị cho toàn bộ hệ thống.</h1>
        <p class="lead">Theo dõi người dùng, bài tập, kế hoạch tập và nhật ký buổi tập từ một màn hình tổng hợp.</p>
    </div>
    <div class="hero-actions">
        <a class="button" asp-controller="AdminExercises" asp-action="Index">Quản lý bài tập</a>
        <a class="button button--ghost" asp-controller="AdminUsers" asp-action="Index">Quản lý người dùng</a>
    </div>
</section>

<section class="metric-grid">
    <article class="metric-card"><span class="metric-card__label">Tổng người dùng</span><strong>@Model.TotalUsers</strong></article>
    <article class="metric-card"><span class="metric-card__label">Người dùng hoạt động</span><strong>@Model.ActiveUsers</strong></article>
    <article class="metric-card"><span class="metric-card__label">Bài tập</span><strong>@Model.TotalExercises</strong></article>
    <article class="metric-card"><span class="metric-card__label">Kế hoạch / Nhật ký</span><strong>@Model.TotalPlans / @Model.TotalLogs</strong></article>
</section>

<section class="content-grid content-grid--2">
    <article class="surface-card js-reveal">
        <div class="card-head">
            <div>
                <p class="eyebrow">Người dùng mới</p>
                <h2>Tài khoản gần đây</h2>
            </div>
            <a asp-controller="AdminUsers" asp-action="Index">Xem tất cả</a>
        </div>

        @if (Model.RecentUsers.Any())
        {
            <div class="stack-list">
                @foreach (var user in Model.RecentUsers)
                {
                    <article class="stack-item">
                        <div class="stack-item__head">
                            <strong>@user.FullName</strong>
                            <span>@user.Role</span>
                        </div>
                        <p>@user.Username | @user.Email</p>
                    </article>
                }
            </div>
        }
        else
        {
            <p class="empty-state">Chưa có người dùng nào trong hệ thống.</p>
        }
    </article>

    <article class="surface-card js-reveal">
        <div class="card-head">
            <div>
                <p class="eyebrow">Tác vụ quản trị</p>
                <h2>Chức năng hiện có</h2>
            </div>
        </div>

        <div class="stack-list">
            <article class="stack-item">
                <div class="stack-item__head"><strong>Quản lý bài tập</strong><span>CRUD</span></div>
                <p>Tạo, sửa, xóa và theo dõi mức độ sử dụng của bài tập trong kế hoạch và buổi tập.</p>
            </article>
            <article class="stack-item">
                <div class="stack-item__head"><strong>Quản lý người dùng</strong><span>Sửa / Xóa</span></div>
                <p>Cập nhật thông tin, phân quyền, khóa mở tài khoản và xóa người dùng khi cần.</p>
            </article>
        </div>
    </article>
</section>
