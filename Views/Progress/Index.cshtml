@model ProgressViewModel
@{
    ViewData["Title"] = "Tien Do";
}

<section class="page-hero">
    <div>
        <p class="eyebrow">Performance Overview</p>
        <h1>Bang tong hop tien do cua @Model.FullName.</h1>
        <p class="lead">Tong hop so buoi tap, volume, muc tieu va phan bo nhom co duoc tac dong de danh gia qua trinh ren luyen.</p>
    </div>
</section>

<section class="metric-grid">
    <article class="metric-card"><span class="metric-card__label">Tong so session</span><strong>@Model.TotalSessions</strong></article>
    <article class="metric-card"><span class="metric-card__label">Session thang nay</span><strong>@Model.SessionsThisMonth</strong></article>
    <article class="metric-card"><span class="metric-card__label">Tong volume</span><strong>@Model.TotalVolume</strong></article>
    <article class="metric-card"><span class="metric-card__label">Goal completion</span><strong>@Model.GoalCompletionRate%</strong></article>
</section>

<section class="content-grid content-grid--2">
    <article class="surface-card js-reveal">
        <div class="card-head"><div><p class="eyebrow">Trend</p><h2>Session 6 thang gan nhat</h2></div></div>
        <div class="bar-list">
            @foreach (var item in Model.MonthlyWorkouts)
            {
                var width = item.MaxValue == 0 ? 0 : Math.Max(8, item.Value * 100 / item.MaxValue);
                <div class="bar-item">
                    <div class="bar-item__meta"><span>@item.Label</span><span>@item.Hint</span></div>
                    <div class="bar-track"><div class="bar-fill" style="width:@width%"></div></div>
                </div>
            }
        </div>
    </article>

    <article class="surface-card js-reveal">
        <div class="card-head"><div><p class="eyebrow">Muscle Focus</p><h2>Phan bo nhom co</h2></div></div>
        @if (Model.MuscleGroups.Any())
        {
            <div class="bar-list">
                @foreach (var item in Model.MuscleGroups)
                {
                    var width = item.MaxValue == 0 ? 0 : Math.Max(8, item.Value * 100 / item.MaxValue);
                    <div class="bar-item">
                        <div class="bar-item__meta"><span>@item.Label</span><span>@item.Hint</span></div>
                        <div class="bar-track"><div class="bar-fill" style="width:@width%"></div></div>
                    </div>
                }
            </div>
        }
        else
        {
            <p class="empty-state">Chua co du lieu nhom co tu workout log.</p>
        }
    </article>
</section>

<section class="content-grid content-grid--2">
    <article class="surface-card">
        <div class="card-head"><div><p class="eyebrow">Goal Tracker</p><h2>Tien do muc tieu</h2></div></div>
        @if (Model.GoalProgress.Any())
        {
            <div class="stack-list">
                @foreach (var goal in Model.GoalProgress)
                {
                    <article class="stack-item">
                        <div class="stack-item__head"><strong>@goal.Title</strong><span>@goal.Status</span></div>
                        <p>@goal.CurrentValue / @goal.TargetValue @goal.Unit</p>
                        <div class="progress-meter"><div class="progress-meter__fill" style="width:@goal.Percent%"></div></div>
                    </article>
                }
            </div>
        }
        else
        {
            <p class="empty-state">Chua co muc tieu nao duoc thiet lap.</p>
        }
    </article>

    <article class="surface-card">
        <div class="card-head"><div><p class="eyebrow">Recent Activity</p><h2>Buoi tap gan day</h2></div></div>
        @if (Model.RecentWorkouts.Any())
        {
            <div class="stack-list">
                @foreach (var log in Model.RecentWorkouts)
                {
                    <article class="stack-item">
                        <div class="stack-item__head"><strong>@log.WorkoutDate.ToString("dd/MM/yyyy")</strong><span>@log.EnergyLevel</span></div>
                        <p>@log.DurationMinutes phut • @log.DetailCount chi tiet</p>
                    </article>
                }
            </div>
        }
        else
        {
            <p class="empty-state">Chua co hoat dong nao.</p>
        }
    </article>
</section>
