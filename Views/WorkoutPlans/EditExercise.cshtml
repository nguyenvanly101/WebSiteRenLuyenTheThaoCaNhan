@model WorkoutExerciseFormViewModel
@{
    ViewData["Title"] = "Sua Bai Tap";
}

<section class="surface-card">
    <p class="eyebrow">Day</p>
    <h1>Cap nhat bai tap trong @ViewBag.DayLabel</h1>
    <form asp-action="EditExercise" method="post" class="form-stack mt-4">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" class="validation-summary"></div>
        <partial name="_ExerciseForm" model="Model" />
        <button type="submit" class="button">Cap nhat bai tap</button>
    </form>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
