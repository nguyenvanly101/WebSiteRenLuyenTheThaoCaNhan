@using WebsiteRenLuyenTheThaoCaNhan.Infrastructure
@{
    var controller = ViewContext.RouteData.Values["controller"]?.ToString() ?? string.Empty;
    var isAuthenticated = User.Identity?.IsAuthenticated == true;
    var isAdmin = User.IsInRole(AppRoles.Admin);
    var pageShellClass = ViewData["PageShellClass"]?.ToString();
    string NavClass(string controllerName) => controller == controllerName ? "nav-link is-active" : "nav-link";
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Rèn luyện thể thao cá nhân</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/portal.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/WebsiteRenLuyenTheThaoCaNhan.styles.css" asp-append-version="true" />
</head>
<body class="app-shell">
    <div class="ambient ambient-a"></div>
    <div class="ambient ambient-b"></div>
    <header class="site-header">
        <div class="shell site-header-inner">
            <a class="brand-mark" asp-controller="Home" asp-action="Index">
                <span class="brand-mark__tag">Hệ thống tập luyện</span>
                <strong>Quản lý cá nhân</strong>
            </a>

            <nav class="site-nav">
                @if (isAuthenticated && !isAdmin)
                {
                    <a class="@NavClass("Dashboard")" asp-controller="Dashboard" asp-action="Index">Tổng quan</a>
                    <a class="@NavClass("WorkoutPlans")" asp-controller="WorkoutPlans" asp-action="Index">Kế hoạch tập</a>
                    <a class="@NavClass("WorkoutLogs")" asp-controller="WorkoutLogs" asp-action="Index">Buổi tập</a>
                    <a class="@NavClass("Progress")" asp-controller="Progress" asp-action="Index">Tiến độ</a>
                    <a class="@NavClass("Goals")" asp-controller="Goals" asp-action="Index">Mục tiêu</a>
                }
                else if (isAuthenticated && isAdmin)
                {
                    <a class="@NavClass("Admin")" asp-controller="Admin" asp-action="Index">Tổng quan</a>
                    <a class="@NavClass("AdminExercises")" asp-controller="AdminExercises" asp-action="Index">Bài tập</a>
                    <a class="@NavClass("AdminUsers")" asp-controller="AdminUsers" asp-action="Index">Người dùng</a>
                }
                else
                {
                    <a class="@NavClass("Home")" asp-controller="Home" asp-action="Index">Trang chủ</a>
                    <a class="@NavClass("Home")" asp-controller="Home" asp-action="Privacy">Chính sách</a>
                }
            </nav>

            <div class="site-actions">
                @if (isAuthenticated)
                {
                    <div class="identity-chip">
                        <span class="identity-chip__label">@(isAdmin ? "QUẢN TRỊ" : "THÀNH VIÊN")</span>
                        <strong>@(User.Identity?.Name ?? "Người dùng")</strong>
                    </div>
                    <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="button button--ghost">Đăng xuất</button>
                    </form>
                }
                else
                {
                    <a class="button button--ghost" asp-controller="Account" asp-action="Login">Đăng nhập</a>
                    <a class="button" asp-controller="Account" asp-action="Register">Tạo tài khoản</a>
                }
            </div>
        </div>
    </header>

    <div class="shell page-shell @(pageShellClass ?? string.Empty)">
        @await Html.PartialAsync("_Alert")
        <main role="main" class="page-content js-reveal">
            @RenderBody()
        </main>
    </div>

    <footer class="site-footer">
        <div class="shell site-footer-inner">
            <p>Quản lý kế hoạch tập, buổi tập và mục tiêu tại một nơi.</p>
            <a asp-controller="Home" asp-action="Privacy">Xem chính sách</a>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/portal.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
