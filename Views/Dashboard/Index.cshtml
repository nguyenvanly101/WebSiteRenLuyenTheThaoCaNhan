@model DashboardViewModel
@{
    ViewData["Title"] = "Tổng quan";
}

<section class="page-hero">
    <div>
        <p class="eyebrow">Tổng quan cá nhân</p>
        <h1>@Model.FullName, đây là nơi theo dõi kế hoạch tập và kết quả gần đây của bạn.</h1>
        <p class="lead">Xem nhanh số kế hoạch đang hoạt động, buổi tập đã ghi và tình trạng mục tiêu từ một màn hình tổng hợp.</p>
    </div>
    <div class="hero-actions">
        <a class="button" asp-controller="WorkoutPlans" asp-action="Create">Tạo kế hoạch tập</a>
        <a class="button button--ghost" asp-controller="WorkoutLogs" asp-action="Create">Ghi buổi tập</a>
    </div>
</section>

<section class="metric-grid js-reveal">
    <article class="metric-card"><span class="metric-card__label">Kế hoạch đang hoạt động</span><strong>@Model.ActivePlans</strong></article>
    <article class="metric-card"><span class="metric-card__label">Buổi tập đã ghi</span><strong>@Model.CompletedWorkouts</strong></article>
    <article class="metric-card"><span class="metric-card__label">Mục tiêu đang mở</span><strong>@Model.ActiveGoals</strong></article>
    <article class="metric-card"><span class="metric-card__label">Tỷ lệ hoàn thành mục tiêu</span><strong>@Model.GoalCompletionRate%</strong></article>
</section>

<section class="content-grid content-grid--2">
    <article class="surface-card js-reveal">
        <div class="card-head">
            <div><p class="eyebrow">7 ngày gần đây</p><h2>Tần suất tập luyện</h2></div>
        </div>
        <div class="bar-list">
            @foreach (var item in Model.WeeklyWorkouts)
            {
                var width = item.MaxValue == 0 ? 0 : Math.Max(8, item.Value * 100 / item.MaxValue);
                <div class="bar-item">
                    <div class="bar-item__meta"><span>@item.Label</span><span>@item.Hint</span></div>
                    <div class="bar-track"><div class="bar-fill" style="width:@width%"></div></div>
                </div>
            }
        </div>
    </article>

    <article class="surface-card js-reveal">
        <div class="card-head">
            <div><p class="eyebrow">Mục tiêu</p><h2>Đang theo dõi</h2></div>
            <a asp-controller="Goals" asp-action="Index">Quản lý mục tiêu</a>
        </div>
        @if (Model.Goals.Any())
        {
            <div class="stack-list">
                @foreach (var goal in Model.Goals.Take(4))
                {
                    <article class="stack-item">
                        <div class="stack-item__head"><strong>@goal.Title</strong><span>@goal.Status</span></div>
                        <p>@goal.CurrentValue / @goal.TargetValue @goal.Unit</p>
                        <div class="progress-meter"><div class="progress-meter__fill" style="width:@goal.Percent%"></div></div>
                    </article>
                }
            </div>
        }
        else
        {
            <p class="empty-state">Chưa có mục tiêu nào. Hãy tạo mục tiêu mới để hệ thống theo dõi tiến độ.</p>
        }
    </article>
</section>

<section class="content-grid content-grid--2">
    <article class="surface-card js-reveal">
        <div class="card-head">
            <div><p class="eyebrow">Kế hoạch tập</p><h2>Kế hoạch nổi bật</h2></div>
            <a asp-controller="WorkoutPlans" asp-action="Index">Xem tất cả</a>
        </div>
        @if (Model.Plans.Any())
        {
            <div class="stack-list">
                @foreach (var plan in Model.Plans)
                {
                    <article class="stack-item">
                        <div class="stack-item__head"><strong>@plan.PlanName</strong><span>@plan.Level</span></div>
                        <p>@plan.Goal • @plan.DayCount ngày • @plan.ExerciseCount bài tập • @plan.Duration ngày</p>
                        <a asp-controller="WorkoutPlans" asp-action="Details" asp-route-id="@plan.PlanId">Mở chi tiết</a>
                    </article>
                }
            </div>
        }
        else
        {
            <p class="empty-state">Bạn chưa tạo kế hoạch tập nào.</p>
        }
    </article>

    <article class="surface-card js-reveal">
        <div class="card-head">
            <div><p class="eyebrow">Buổi tập</p><h2>Gần đây</h2></div>
            <a asp-controller="WorkoutLogs" asp-action="Index">Xem lịch sử</a>
        </div>
        @if (Model.RecentWorkouts.Any())
        {
            <div class="stack-list">
                @foreach (var log in Model.RecentWorkouts)
                {
                    <article class="stack-item">
                        <div class="stack-item__head"><strong>@log.WorkoutDate.ToString("dd/MM/yyyy")</strong><span>@log.EnergyLevel</span></div>
                        <p>@log.DurationMinutes phút • @log.DetailCount chi tiết</p>
                        <a asp-controller="WorkoutLogs" asp-action="Details" asp-route-id="@log.LogId">Xem buổi tập</a>
                    </article>
                }
            </div>
        }
        else
        {
            <p class="empty-state">Chưa có buổi tập nào được ghi nhận.</p>
        }
    </article>
</section>
