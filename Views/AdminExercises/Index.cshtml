@model IEnumerable<AdminExerciseListItemViewModel>
@{
    ViewData["Title"] = "Quan Ly Bai Tap";
}

<section class="page-hero">
    <div>
        <p class="eyebrow">EXERCISE LIBRARY</p>
        <h1>Quản lý danh mục bài tập dành cho hệ thống chung.</h1>
        <p class="lead">Cập nhật  , thêm , sửa , xóa bài tập.</p>
    </div>
    <div class="hero-actions">
        <a class="button" asp-action="Create">Thêm bài tập</a>
    </div>
</section>

<section class="surface-card">
    <div class="table-shell">
        <table class="table mb-0">
            <thead>
                <tr>
                    <th>Bài tập</th>
                    <th>Nhóm cơ</th>
                    <th>Độ khó</th>
                    <th>Sử dụng trong Plan/th>
                    <th>Sử dụng trong Log</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>
                            <strong>@item.Exercise.Name</strong>
                            <div>@item.Exercise.Equipment</div>
                        </td>
                        <td>@item.Exercise.MuscleGroup</td>
                        <td>@item.Exercise.Difficulty</td>
                        <td>@item.PlanUsageCount</td>
                        <td>@item.LogUsageCount</td>
                        <td>
                            <div class="actions-row">
                                <a asp-action="Edit" asp-route-id="@item.Exercise.ExerciseID">Sua</a>
                                <a asp-action="Delete" asp-route-id="@item.Exercise.ExerciseID">Xoa</a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (!Model.Any())
    {
        <p class="empty-state mt-4">Chua co bai tap nao trong he thong.</p>
    }
</section>
