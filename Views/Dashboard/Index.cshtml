@model DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
}

<section class="page-hero">
    <div>
        <p class="eyebrow">ATHLETE DASHBOARD</p>
        <h1>@Model.FullName, day la trung tam dieu phoi lich tap va tracking cua ban.</h1>
        <p class="lead">Theo doi so ke hoach dang van hanh, buoi tap da hoan thanh va muc do tien sat muc tieu tu mot man hinh tong quan.</p>
    </div>
    <div class="hero-actions">
        <a class="button" asp-controller="WorkoutPlans" asp-action="Create">Tao lich tap</a>
        <a class="button button--ghost" asp-controller="WorkoutLogs" asp-action="Create">Ghi nhan buoi tap</a>
    </div>
</section>

<section class="metric-grid js-reveal">
    <article class="metric-card"><span class="metric-card__label">Ke hoach dang chay</span><strong>@Model.ActivePlans</strong></article>
    <article class="metric-card"><span class="metric-card__label">Buoi tap da ghi nhan</span><strong>@Model.CompletedWorkouts</strong></article>
    <article class="metric-card"><span class="metric-card__label">Muc tieu dang mo</span><strong>@Model.ActiveGoals</strong></article>
    <article class="metric-card"><span class="metric-card__label">Ty le hoan thanh muc tieu</span><strong>@Model.GoalCompletionRate%</strong></article>
</section>

<section class="content-grid content-grid--2">
    <article class="surface-card js-reveal">
        <div class="card-head">
            <div><p class="eyebrow">Weekly Rhythm</p><h2>Tan suat tap 7 ngay gan nhat</h2></div>
        </div>
        <div class="bar-list">
            @foreach (var item in Model.WeeklyWorkouts)
            {
                var width = item.MaxValue == 0 ? 0 : Math.Max(8, item.Value * 100 / item.MaxValue);
                <div class="bar-item">
                    <div class="bar-item__meta"><span>@item.Label</span><span>@item.Hint</span></div>
                    <div class="bar-track"><div class="bar-fill" style="width:@width%"></div></div>
                </div>
            }
        </div>
    </article>

    <article class="surface-card js-reveal">
        <div class="card-head">
            <div><p class="eyebrow">Goals</p><h2>Muc tieu dang theo doi</h2></div>
            <a asp-controller="Goals" asp-action="Index">Quan ly muc tieu</a>
        </div>
        @if (Model.Goals.Any())
        {
            <div class="stack-list">
                @foreach (var goal in Model.Goals.Take(4))
                {
                    <article class="stack-item">
                        <div class="stack-item__head"><strong>@goal.Title</strong><span>@goal.Status</span></div>
                        <p>@goal.CurrentValue / @goal.TargetValue @goal.Unit</p>
                        <div class="progress-meter"><div class="progress-meter__fill" style="width:@goal.Percent%"></div></div>
                    </article>
                }
            </div>
        }
        else
        {
            <p class="empty-state">Chua co muc tieu nao. Tao muc tieu moi de he thong theo doi tien do.</p>
        }
    </article>
</section>

<section class="content-grid content-grid--2">
    <article class="surface-card js-reveal">
        <div class="card-head">
            <div><p class="eyebrow">Workout Plans</p><h2>Ke hoach noi bat</h2></div>
            <a asp-controller="WorkoutPlans" asp-action="Index">Xem tat ca</a>
        </div>
        @if (Model.Plans.Any())
        {
            <div class="stack-list">
                @foreach (var plan in Model.Plans)
                {
                    <article class="stack-item">
                        <div class="stack-item__head"><strong>@plan.PlanName</strong><span>@plan.Level</span></div>
                        <p>@plan.Goal • @plan.DayCount ngay • @plan.ExerciseCount bai tap • @plan.Duration ngay</p>
                        <a asp-controller="WorkoutPlans" asp-action="Details" asp-route-id="@plan.PlanId">Mo chi tiet</a>
                    </article>
                }
            </div>
        }
        else
        {
            <p class="empty-state">Ban chua tao ke hoach tap nao.</p>
        }
    </article>

    <article class="surface-card js-reveal">
        <div class="card-head">
            <div><p class="eyebrow">Recent Logs</p><h2>Buoi tap gan day</h2></div>
            <a asp-controller="WorkoutLogs" asp-action="Index">Xem lich su</a>
        </div>
        @if (Model.RecentWorkouts.Any())
        {
            <div class="stack-list">
                @foreach (var log in Model.RecentWorkouts)
                {
                    <article class="stack-item">
                        <div class="stack-item__head"><strong>@log.WorkoutDate.ToString("dd/MM/yyyy")</strong><span>@log.EnergyLevel</span></div>
                        <p>@log.DurationMinutes phut • @log.DetailCount chi tiet</p>
                        <a asp-controller="WorkoutLogs" asp-action="Details" asp-route-id="@log.LogId">Xem buoi tap</a>
                    </article>
                }
            </div>
        }
        else
        {
            <p class="empty-state">Chua co workout log nao duoc ghi nhan.</p>
        }
    </article>
</section>
