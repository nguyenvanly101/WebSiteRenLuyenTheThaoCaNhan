@model ProgressViewModel
@{
    ViewData["Title"] = "Tiến độ";
}

<section class="page-hero">
    <div>
        <p class="eyebrow">Tiến độ</p>
        <h1>Bảng tổng hợp tiến độ của @Model.FullName.</h1>
        <p class="lead">Tổng hợp số buổi tập, khối lượng tập, mục tiêu và phân bố nhóm cơ để đánh giá quá trình rèn luyện.</p>
    </div>
</section>

<section class="metric-grid">
    <article class="metric-card"><span class="metric-card__label">Tổng số buổi tập</span><strong>@Model.TotalSessions</strong></article>
    <article class="metric-card"><span class="metric-card__label">Buổi tập trong tháng</span><strong>@Model.SessionsThisMonth</strong></article>
    <article class="metric-card"><span class="metric-card__label">Tổng volume</span><strong>@Model.TotalVolume</strong></article>
    <article class="metric-card"><span class="metric-card__label">Hoàn thành mục tiêu</span><strong>@Model.GoalCompletionRate%</strong></article>
</section>

<section class="content-grid content-grid--2">
    <article class="surface-card js-reveal">
        <div class="card-head"><div><p class="eyebrow">Xu hướng</p><h2>Buổi tập trong 6 tháng gần nhất</h2></div></div>
        <div class="bar-list">
            @foreach (var item in Model.MonthlyWorkouts)
            {
                var width = item.MaxValue == 0 ? 0 : Math.Max(8, item.Value * 100 / item.MaxValue);
                <div class="bar-item">
                    <div class="bar-item__meta"><span>@item.Label</span><span>@item.Hint</span></div>
                    <div class="bar-track"><div class="bar-fill" style="width:@width%"></div></div>
                </div>
            }
        </div>
    </article>

    <article class="surface-card js-reveal">
        <div class="card-head"><div><p class="eyebrow">Nhóm cơ</p><h2>Phân bố tác động</h2></div></div>
        @if (Model.MuscleGroups.Any())
        {
            <div class="bar-list">
                @foreach (var item in Model.MuscleGroups)
                {
                    var width = item.MaxValue == 0 ? 0 : Math.Max(8, item.Value * 100 / item.MaxValue);
                    <div class="bar-item">
                        <div class="bar-item__meta"><span>@item.Label</span><span>@item.Hint</span></div>
                        <div class="bar-track"><div class="bar-fill" style="width:@width%"></div></div>
                    </div>
                }
            </div>
        }
        else
        {
            <p class="empty-state">Chưa có dữ liệu nhóm cơ từ nhật ký buổi tập.</p>
        }
    </article>
</section>

<section class="content-grid content-grid--2">
    <article class="surface-card">
        <div class="card-head"><div><p class="eyebrow">Mục tiêu</p><h2>Tiến độ hiện tại</h2></div></div>
        @if (Model.GoalProgress.Any())
        {
            <div class="stack-list">
                @foreach (var goal in Model.GoalProgress)
                {
                    <article class="stack-item">
                        <div class="stack-item__head"><strong>@goal.Title</strong><span>@goal.Status</span></div>
                        <p>@goal.CurrentValue / @goal.TargetValue @goal.Unit</p>
                        <div class="progress-meter"><div class="progress-meter__fill" style="width:@goal.Percent%"></div></div>
                    </article>
                }
            </div>
        }
        else
        {
            <p class="empty-state">Chưa có mục tiêu nào được thiết lập.</p>
        }
    </article>

    <article class="surface-card">
        <div class="card-head"><div><p class="eyebrow">Hoạt động gần đây</p><h2>Buổi tập gần nhất</h2></div></div>
        @if (Model.RecentWorkouts.Any())
        {
            <div class="stack-list">
                @foreach (var log in Model.RecentWorkouts)
                {
                    <article class="stack-item">
                        <div class="stack-item__head"><strong>@log.WorkoutDate.ToString("dd/MM/yyyy")</strong><span>@log.EnergyLevel</span></div>
                        <p>@log.DurationMinutes phút • @log.DetailCount chi tiết</p>
                    </article>
                }
            </div>
        }
        else
        {
            <p class="empty-state">Chưa có hoạt động nào.</p>
        }
    </article>
</section>
