@model GoalFormViewModel
@{
    ViewData["Title"] = "Tao Muc Tieu";
}

<section class="surface-card">
    <p class="eyebrow">Create Goal</p>
    <h1>Tao muc tieu moi</h1>
    <form asp-action="Create" method="post" class="form-stack mt-4">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" class="validation-summary"></div>
        <partial name="_GoalForm" model="Model" />
        <div class="actions-row">
            <button type="submit" class="button">Luu muc tieu</button>
            <a class="button button--ghost" asp-action="Index">Quay lai</a>
        </div>
    </form>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
