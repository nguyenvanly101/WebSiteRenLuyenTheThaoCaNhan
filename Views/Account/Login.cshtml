@model LoginViewModel
@{
    ViewData["Title"] = "Đăng nhập";
}

<section class="auth-shell">
    <div class="auth-copy js-reveal">
        <p class="eyebrow">Đăng nhập</p>
        <h1>Đăng nhập để tiếp tục theo dõi việc tập luyện.</h1>
        <p class="lead">Sau khi đăng nhập, bạn có thể mở lại kế hoạch tập, nhật ký buổi tập và các mục tiêu đang theo dõi.</p>
        
    </div>

    <div class="auth-card js-reveal">
        <div class="auth-card__header">
            <p class="eyebrow">Biểu mẫu</p>
            <h2>Đăng nhập tài khoản</h2>
            <p class="form-footnote">Nhập tên đăng nhập hoặc email để tiếp tục.</p>
        </div>

        <form asp-action="Login" method="post" class="form-stack">
            @Html.AntiForgeryToken()
            <input type="hidden" name="returnUrl" value="@ViewData["ReturnUrl"]" />
            <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

            <div class="field">
                <label asp-for="Login"></label>
                <input asp-for="Login" class="form-control" />
                <span asp-validation-for="Login" class="text-danger"></span>
            </div>

            <div class="field">
                <label asp-for="Password"></label>
                <input asp-for="Password" class="form-control" />
                <span asp-validation-for="Password" class="text-danger"></span>
            </div>

            <label class="checkbox-line">
                <input asp-for="RememberMe" />
                <span>Ghi nhớ phiên đăng nhập</span>
            </label>

            <button type="submit" class="button button--block">Đăng nhập</button>
            <p class="form-footnote">Chưa có tài khoản? <a asp-action="Register">Đăng ký ngay</a></p>
        </form>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
