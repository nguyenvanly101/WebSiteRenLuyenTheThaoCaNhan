@model Exercise
@{
    ViewData["Title"] = "Xoa Bai Tap";
}

<section class="surface-card">
    <p class="eyebrow">Admin</p>
    <h1>Xoa bai tap @Model.Name</h1>
    <p class="lead">Thao tac nay chi thanh cong khi bai tap chua duoc gan vao lich tap hoac workout log.</p>

    <div class="stack-list mt-4">
        <article class="stack-item"><strong>Nhom co:</strong> @Model.MuscleGroup</article>
        <article class="stack-item"><strong>Thiet bi:</strong> @Model.Equipment</article>
        <article class="stack-item"><strong>Do kho:</strong> @Model.Difficulty</article>
    </div>

    <form asp-action="Delete" method="post" class="actions-row mt-4">
        @Html.AntiForgeryToken()
        <button type="submit" class="button">Xac nhan xoa</button>
        <a class="button button--ghost" asp-action="Index">Huy</a>
    </form>
</section>
