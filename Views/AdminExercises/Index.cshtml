@model IEnumerable<AdminExerciseListItemViewModel>
@{
    ViewData["Title"] = "Quan Ly Bai Tap";
}

<section class="page-hero">
    <div>
        <p class="eyebrow">EXERCISE LIBRARY</p>
        <h1>Quan ly danh muc bai tap dung chung cho toan he thong.</h1>
        <p class="lead">Admin co the tao moi, cap nhat, xoa va theo doi bai tap dang duoc su dung o dau.</p>
    </div>
    <div class="hero-actions">
        <a class="button" asp-action="Create">Them bai tap</a>
    </div>
</section>

<section class="surface-card">
    <div class="table-shell">
        <table class="table table-dark mb-0">
            <thead>
                <tr>
                    <th>Bai tap</th>
                    <th>Nhom co</th>
                    <th>Do kho</th>
                    <th>Su dung trong plan</th>
                    <th>Su dung trong log</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>
                            <strong>@item.Exercise.Name</strong>
                            <div>@item.Exercise.Equipment</div>
                        </td>
                        <td>@item.Exercise.MuscleGroup</td>
                        <td>@item.Exercise.Difficulty</td>
                        <td>@item.PlanUsageCount</td>
                        <td>@item.LogUsageCount</td>
                        <td>
                            <div class="actions-row">
                                <a asp-action="Edit" asp-route-id="@item.Exercise.ExerciseID">Sua</a>
                                <a asp-action="Delete" asp-route-id="@item.Exercise.ExerciseID">Xoa</a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (!Model.Any())
    {
        <p class="empty-state mt-4">Chua co bai tap nao trong he thong.</p>
    }
</section>
