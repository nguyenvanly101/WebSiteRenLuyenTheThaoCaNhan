@model GoalFormViewModel

<div class="field">
    <label asp-for="Title"></label>
    <input asp-for="Title" class="form-control" />
    <span asp-validation-for="Title" class="text-danger"></span>
</div>

<div class="field-grid">
    <div class="field">
        <label asp-for="GoalType"></label>
        <select asp-for="GoalType" asp-items="ViewBag.GoalTypes" class="form-select"></select>
        <span asp-validation-for="GoalType" class="text-danger"></span>
    </div>
    <div class="field">
        <label asp-for="Unit"></label>
        <select asp-for="Unit" asp-items="ViewBag.Units" class="form-select"></select>
        <span asp-validation-for="Unit" class="text-danger"></span>
    </div>
</div>

<div class="field-grid">
    <div class="field">
        <label asp-for="TargetValue"></label>
        <input asp-for="TargetValue" class="form-control" />
        <span asp-validation-for="TargetValue" class="text-danger"></span>
    </div>
    <div class="field">
        <label asp-for="CurrentValue"></label>
        <input asp-for="CurrentValue" class="form-control" />
        <span asp-validation-for="CurrentValue" class="text-danger"></span>
    </div>
</div>

<div class="field-grid">
    <div class="field">
        <label asp-for="StartDate"></label>
        <input asp-for="StartDate" type="date" class="form-control" />
        <span asp-validation-for="StartDate" class="text-danger"></span>
    </div>
    <div class="field">
        <label asp-for="EndDate"></label>
        <input asp-for="EndDate" type="date" class="form-control" />
        <span asp-validation-for="EndDate" class="text-danger"></span>
    </div>
</div>

<div class="field">
    <label asp-for="Status"></label>
    <select asp-for="Status" asp-items="ViewBag.GoalStatuses" class="form-select"></select>
    <span asp-validation-for="Status" class="text-danger"></span>
</div>
