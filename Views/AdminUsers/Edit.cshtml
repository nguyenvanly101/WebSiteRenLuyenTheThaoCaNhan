@model AdminUserEditViewModel
@{
    ViewData["Title"] = "Sua Nguoi Dung";
}

<section class="surface-card">
    <p class="eyebrow">Admin</p>
    <h1>Cap nhat thong tin nguoi dung</h1>
    <form asp-action="Edit" method="post" class="form-stack mt-4">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

        <div class="field">
            <label asp-for="FullName"></label>
            <input asp-for="FullName" class="form-control" />
            <span asp-validation-for="FullName" class="text-danger"></span>
        </div>

        <div class="field-grid">
            <div class="field">
                <label asp-for="Username"></label>
                <input asp-for="Username" class="form-control" />
                <span asp-validation-for="Username" class="text-danger"></span>
            </div>
            <div class="field">
                <label asp-for="Email"></label>
                <input asp-for="Email" class="form-control" />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>
        </div>

        <div class="field-grid">
            <div class="field">
                <label asp-for="Role"></label>
                <select asp-for="Role" asp-items="ViewBag.Roles" class="form-select"></select>
                <span asp-validation-for="Role" class="text-danger"></span>
            </div>
            <div class="field">
                <label class="checkbox-line">
                    <input asp-for="IsActive" />
                    <span>Cho phep dang nhap</span>
                </label>
                <span asp-validation-for="IsActive" class="text-danger"></span>
            </div>
        </div>

        <div class="actions-row">
            <button type="submit" class="button">Cap nhat</button>
            <a class="button button--ghost" asp-action="Index">Quay lai</a>
        </div>
    </form>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
